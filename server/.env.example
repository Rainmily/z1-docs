# 掌上乾坤文档站 - 多企业微信登录配置
# 复制此文件为 .env 并填写实际值

# ── 服务配置 ─────────────────────────────────────────────────
PORT=3001

# 前端站点地址（用于 CORS 和回调）
FRONTEND_URL=https://docs.whohi.cn

# Session 密钥（请改为随机字符串）
SESSION_SECRET=change-this-to-random-secret

# ── 多企业微信配置（必填！）───────────────────────────────────
#
# 格式：JSON 数组，每个对象代表一个企业
# 至少需要一个企业的配置
#
# 字段说明：
#   id          : 企业的唯一标识符（英文/数字，用于 URL 和回调路由）
#   name        : 在登录页显示的企业名称
#   logo        : 企业 logo 图片 URL（可选，留空显示首字母）
#   corpId      : 企业 ID（ww 开头的字符串，企业信息页获取）
#   agentId     : 应用 AgentID（应用详情页获取）
#   agentSecret : 应用 Secret（应用详情页获取）
#   allowedUsers: 允许登录的成员 userid（留空=允许所有成员）
#
# ──────────────────────────────────────────────────────────────
# 示例：配置 3 家企业（掌上乾坤 + 2 家合作伙伴）
# ──────────────────────────────────────────────────────────────
MULTI_WECOM_CONFIG='[
  {
    "id": "zsqk",
    "name": "掌上乾坤",
    "logo": "",
    "corpId": "ww1234567890abcd",
    "agentId": "1000001",
    "agentSecret": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
    "allowedUsers": ""
  },
  {
    "id": "partner-a",
    "name": "合作伙伴A公司",
    "logo": "",
    "corpId": "wwabcdef12345678",
    "agentId": "1000002",
    "agentSecret": "yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy",
    "allowedUsers": "zhangsan,lisi"
  },
  {
    "id": "partner-b",
    "name": "合作伙伴B公司",
    "logo": "",
    "corpId": "wwghijkl78901234",
    "agentId": "1000003",
    "agentSecret": "zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz",
    "allowedUsers": ""
  }
]'

# ── 兼容旧配置（单企业模式）───────────────────────────────────
# 如果没有配置 MULTI_WECOM_CONFIG，则使用以下旧配置（单企业）
# 推荐使用上方 MULTI_WECOM_CONFIG 替代以下配置
#
# WECOM_CORP_ID=ww1234567890abcd
# WECOM_AGENT_ID=1000001
# WECOM_AGENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WECOM_COMPANY_NAME=掌上乾坤
# ALLOWED_USERS=
